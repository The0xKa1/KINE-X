{
  "name": "kine-x-frontend-prototype",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --no-warnings=ExperimentalWarning scripts/build.mjs",
    "test:avatar": "npm run build && node --test scripts/avatar-*.test.mjs",

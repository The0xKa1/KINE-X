{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kine-x.local/schemas/frame-stream.schema.json",
  "title": "FRAME_STREAM packet",
  "description": "KINE//X 前后端对齐的核心数据包。所有 3D 坐标单位为米，坐标系为右手系（Y 上、X 右、Z 朝屏幕外），旋转统一使用 [x, y, z, w] 四元数。joints 与 seedJoints 使用同一组 17 个关节名。",
  "type": "object",
  "required": ["type", "data"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "FRAME_STREAM" },
    "data": { "$ref": "#/$defs/motionFrame" }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "[x, y, z]，单位：米"
    },
    "quaternion": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4,
      "description": "[x, y, z, w] 四元数"
    },
    "jointName": {
      "type": "string",
      "enum": [
        "pelvis",
        "spine",
        "chest",
        "neck",
        "head",
        "lShoulder",
        "rShoulder",
        "lElbow",
        "rElbow",
        "lWrist",
        "rWrist",
        "lHip",
        "rHip",
        "lKnee",
        "rKnee",
        "lAnkle",
        "rAnkle"
      ]
    },
    "jointState": {
      "type": "object",
      "required": ["position", "rotation"],
      "additionalProperties": false,
      "properties": {
        "position": { "$ref": "#/$defs/vec3" },
        "rotation": { "$ref": "#/$defs/quaternion" }
      }
    },
    "skeletonPose": {
      "type": "object",
      "description": "17 关节位姿；键为 jointName，每个键都必须出现",
      "required": [
        "pelvis",
        "spine",
        "chest",
        "neck",
        "head",
        "lShoulder",
        "rShoulder",
        "lElbow",
        "rElbow",
        "lWrist",
        "rWrist",
        "lHip",
        "rHip",
        "lKnee",
        "rKnee",
        "lAnkle",
        "rAnkle"
      ],
      "additionalProperties": false,
      "properties": {
        "pelvis": { "$ref": "#/$defs/jointState" },
        "spine": { "$ref": "#/$defs/jointState" },
        "chest": { "$ref": "#/$defs/jointState" },
        "neck": { "$ref": "#/$defs/jointState" },
        "head": { "$ref": "#/$defs/jointState" },
        "lShoulder": { "$ref": "#/$defs/jointState" },
        "rShoulder": { "$ref": "#/$defs/jointState" },
        "lElbow": { "$ref": "#/$defs/jointState" },
        "rElbow": { "$ref": "#/$defs/jointState" },
        "lWrist": { "$ref": "#/$defs/jointState" },
        "rWrist": { "$ref": "#/$defs/jointState" },
        "lHip": { "$ref": "#/$defs/jointState" },
        "rHip": { "$ref": "#/$defs/jointState" },
        "lKnee": { "$ref": "#/$defs/jointState" },
        "rKnee": { "$ref": "#/$defs/jointState" },
        "lAnkle": { "$ref": "#/$defs/jointState" },
        "rAnkle": { "$ref": "#/$defs/jointState" }
      }
    },
    "jointMetric": {
      "type": "object",
      "required": ["id", "name", "base", "variance", "angle", "distance", "score", "angleDeltaDeg", "distanceDeltaCm", "risk"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "指标 id（knee/hip/spine/ankle/shoulder/wrist）" },
        "name": { "type": "string", "description": "展示名（中文，如 膝关节屈伸）" },
        "base": { "type": "number", "description": "权重" },
        "variance": { "type": "number" },
        "angle": { "type": "number", "description": "基准角度容差（度）" },
        "distance": { "type": "number", "description": "基准距离容差（厘米）" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "angleDeltaDeg": { "type": "number", "description": "实测关节角度差（度）" },
        "distanceDeltaCm": { "type": "number", "description": "实测关节偏移（厘米）" },
        "risk": { "type": "string", "enum": ["good", "warn", "risk"] }
      }
    },
    "motionFrame": {
      "type": "object",
      "required": [
        "frame",
        "timestampMs",
        "seedId",
        "progress",
        "score",
        "combo",
        "riskLabel",
        "globalTransform",
        "seedJoints",
        "joints",
        "localRotations",
        "metrics"
      ],
      "additionalProperties": false,
      "properties": {
        "frame": { "type": "integer", "minimum": 0 },
        "timestampMs": { "type": "number", "minimum": 0 },
        "seedId": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "combo": { "type": "integer", "minimum": 0 },
        "riskLabel": { "type": "string" },
        "globalTransform": {
          "type": "object",
          "required": ["translation", "rotation"],
          "additionalProperties": false,
          "properties": {
            "translation": { "$ref": "#/$defs/vec3" },
            "rotation": { "$ref": "#/$defs/quaternion" }
          }
        },
        "seedJoints": {
          "$ref": "#/$defs/skeletonPose",
          "description": "标准动作骨架（教练）"
        },
        "joints": {
          "$ref": "#/$defs/skeletonPose",
          "description": "练习者骨架（未接入摄像头时与 seedJoints 相同）"
        },
        "localRotations": {
          "type": "array",
          "items": { "$ref": "#/$defs/quaternion" },
          "description": "骨骼局部旋转序列，供渲染层 slerp 平滑"
        },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/jointMetric" }
        }
      }
    }
  }
}

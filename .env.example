# Copy this file to .env (which is gitignored) and fill in your real values.
# Used by `npm run server` to populate the FastAPI proxy backend.
#
# BASE_URL must include the OpenAI-compatible /v1 prefix — the backend
# appends /chat/completions directly to whatever you set here.

LLM_BASE_URL=https://api.openai-next.com/v1
LLM_API_KEY=replace-me-with-your-rotated-key
LLM_MODEL=gpt-5.5

# Optional: comma-separated origins allowed to call the backend.
# Defaults to http://localhost:5173,http://127.0.0.1:5173 if unset.
# KINEX_CORS_ORIGINS=http://localhost:5173

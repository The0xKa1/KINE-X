# Dependencies
node_modules/

# Local deploy secrets (SSH keys, AutoDL scripts — never commit)
.deploy-tmp/

# Local development state
.claude/
.superpowers/
.worktrees/
.vscode/
.idea/
.kimi-code/
.playwright-mcp/
promo/
*.iml

# Build / debug artifacts (dist/ IS committed — index.html loads ./dist/main.js directly)
*.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backend job outputs (per-upload artifacts; can be regenerated)
public/coach_clips/jobs/
public/coach_clips/avatar-identities/
public/coach_clips/motions/
public/coach_clips/avatar-bindings/
public/coach_clips/avatar-video-exports/

# LLM proxy backend venv (created by `npm run server:install`)
server/.venv/

# Python bytecode
__pycache__/
*.pyc

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Editor / system
.history/
.cache/
.codegraph/
